{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@boardhub/shared": ["packages/shared/src/index.ts"],
      "@boardhub/shared/*": ["packages/shared/src/*"],
      "@boardhub/engine": ["packages/engine/src/index.ts"],
      "@boardhub/engine/*": ["packages/engine/src/*"]
    }
  }
}
