# Server
PORT=4000
HOST=0.0.0.0
# Comma separated list of allowed web origins. Leave empty to allow all (LAN/Tailscale dev).
CORS_ORIGIN=
# Secret used to sign session tokens. Change this for any real deployment.
JWT_SECRET=change-me-in-production-boardhub

# Persistence. Leave DATABASE_URL empty to use the zero-config file store.
# To use Postgres or Supabase local, set a connection string, e.g.:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/boardhub
DATABASE_URL=

# Web (Vite). URL of the server as reached from the browser.
# Leave empty to use a relative path through the Vite dev proxy.
VITE_SERVER_URL=
